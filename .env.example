# Copy this to .env and fill in your values

# Get from: console.groq.com → API Keys → Create API key (FREE, no credit card)
GROQ_API_KEY=your_groq_api_key_here

# Get from FastField: My Profile > Security > Manage API Tokens
FASTFIELD_API_KEY=7ecba7a70c8c45048b97cad9276ead98

# Your FastField form ID (from exported filename)
FASTFIELD_FORM_ID=668283

# Default FastField user to assign dispatches to
FASTFIELD_RECIPIENT_EMAIL=your@email.com

# Password your whole team uses to log in
APP_PASSWORD=choose_a_team_password_here

# A random secret string (can be anything long and random)
SECRET_KEY=some-long-random-string-here
